<main id="page-<%= pageData.template %>">
    <section class="sec-transaction">
        <div class="inner">
            <div class="transaction-block">
                <div class="transaction-block__icon">
                    <img src="<%= RELATIVE_PATH %>img/common/icon-error.png" alt="Success">
                </div>
                <h2 class="transaction-block__ttl">Giao dịch không thành công</h2>
                <p class="c-txt__basic transaction-block__desc">Giao dịch không thành công. Vui lòng liên hệ với chúng tôi để được hỗ trợ.</p>
                <div class="transaction-block__detail">
                    <dl class="transaction-block__detail-left">
                        <dt>Số tiền</dt>
                        <dd>50,000 VND</dd>
                    </dl>
                    <dl class="transaction-block__detail-right">
                        <dt>Mã giao dịch</dt>
                        <dd>639117309788732735</dd>
                    </dl>
                </div>
                <div class="group-control">
                    <a href="#" class="group-control__btn">Xem lịch sử giao dịch</a>
                    <a href="#" class="group-control__btn">Thực hiện giao dịch mới</a>
                </div>
            </div>
        </div>
    </section>
    <section class="sec-transaction">
        <div class="inner">
            <div class="transaction-block">
                <div class="transaction-block__icon">
                    <img src="<%= RELATIVE_PATH %>img/common/icon-success.png" alt="Success">
                </div>
                <h2 class="transaction-block__ttl">Giao dịch thành công</h2>
                <p class="c-txt__basic transaction-block__desc">
                    Bạn đã nạp thành công 
                    <span>10.000 3CCOIN</span>
                </p>
                <div class="transaction-block__detail">
                    <dl class="transaction-block__detail-left">
                        <dt>Số tiền</dt>
                        <dd>50,000 VND</dd>
                    </dl>
                    <dl class="transaction-block__detail-right">
                        <dt>Mã giao dịch</dt>
                        <dd>639117309788732735</dd>
                    </dl>
                </div>
                <div class="group-control">
                    <a href="#" class="group-control__btn">Xem lịch sử giao dịch</a>
                    <a href="#" class="group-control__btn">Thực hiện giao dịch mới</a>
                </div>
            </div>
        </div>
    </section>
</main>