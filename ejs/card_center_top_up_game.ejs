<main id="page-<%= pageData.template %>">
	<section class="top-up">
		<div class="inner">
			<div class="xu-block">
				<h2 class="c-ttl__03 xu-block__ttl">Chọn phương thức thanh toán</h2>
				<div class="xu-block__payment">
					<div class="input-group">
						<input type="radio" name="payment" value="vnpay" checked>
						<label class="xu-block__payment-input">
							<span class="xu-block__payment-icon">
								<img src="<%= RELATIVE_PATH %>img/card_center/top_up_game/vnpay.png" alt="VNPAY">
							</span>
							<span class="xu-block__payment-info">
								<span>VNPAY</span>
								<span><span class="c-ft--en">1000</span> VNĐ = 1 3CCOIN</span>
							</span>
						</label>
					</div>
					<div class="input-group">
						<input type="radio" name="payment" value="momo">
						<label class="xu-block__payment-input">
							<span class="xu-block__payment-icon">
								<img src="<%= RELATIVE_PATH %>img/card_center/top_up_game/momo.png" alt="momo">
							</span>
							<span class="xu-block__payment-info">
								<span>MOMO</span>
								<span><span class="c-ft--en">1000</span> VNĐ = 1 3CCOIN</span>
							</span>
						</label>
					</div>
					<div class="input-group">
						<input type="radio" name="payment" value="xsolla">
						<label class="xu-block__payment-input">
							<span class="xu-block__payment-icon">
								<img src="<%= RELATIVE_PATH %>img/card_center/top_up_game/xsolla.png" alt="VNPAY">
							</span>
							<span class="xu-block__payment-info">
								<span>Xsolla</span>
								<span>1 USD = 25 3CCOIN</span>
							</span>
						</label>
					</div>
				</div>
				<h2 class="c-ttl__03">Số tiền</h2>
				<div class="xu-block__amount">
					<h3 class="c-ttl__03 xu-block__amount-ttl">Chọn nhanh số tiền</h3>
					<ul class="xu-block__amount-radio">
						<li>
							<label>
								<input type="radio" name="amount" value="50000" checked>
								<span>50.000đ</span>
							</label>
						</li>
						<li>
							<label>
								<input type="radio" name="amount" value="100000">
								<span>100.000đ</span>
							</label>
						</li>
						<li>
							<label>
								<input type="radio" name="amount" value="200000">
								<span>200.000đ</span>
							</label>
						</li>
						<li>
							<label>
								<input type="radio" name="amount" value="300000">
								<span>300.000đ</span>
							</label>
						</li>
						<li>
							<label>
								<input type="radio" name="amount" value="500000">
								<span>500.000đ</span>
							</label>
						</li>
						<li>
							<label>
								<input type="radio" name="amount" value="1000000">
								<span>1.000.000đ</span>
							</label>
						</li>
						<li>
							<label>
								<input type="radio" name="amount" value="2000000">
								<span>2.000.000đ</span>
							</label>
						</li>
						<li>
							<label>
								<input type="radio" name="amount" value="other">
								<span>Số khác</span>
							</label>
						</li>
					</ul>
				</div>
				<div class="amount-detail" id="amount-detail" style="display: none;">
					<h3 class="c-ttl__03 amount-detail__ttl">Số tiền</h3>
					<div class="amount-detail__input">
						<input type="text" class="form-control" inputmode="numeric" id="amount">
						<span class="amount-detail__input-vnd">
							VNĐ
						</span>
					</div>
				</div>
				<div class="xu-block__conversion xu-block__conversion--ungrid">
					<h4 class="c-ttl__03 xu-block__conversion-ttl">Chọn hình thức nạp</h4>
					<ul class="xu-block__conversion-list">
						<li>
							<input type="radio" name="conversion" value="game" checked>
							<label class="xu-block__conversion-input">
								<span class="xu-block__conversion-icon">
									<img src="<%= RELATIVE_PATH %>img/card_center/top_up_game/game.png" alt="Game">
								</span>
								<span class="xu-block__conversion-info">
									<span>Nạp vào game</span>
									<span>Tiền được nạp vào game bạn chọn</span>
								</span>
							</label>
						</li>
						<li>
							<input type="radio" name="conversion" value="wallet">
							<label class="xu-block__conversion-input">
								<span class="xu-block__conversion-icon">
									<img src="<%= RELATIVE_PATH %>img/card_center/top_up_game/wallet.png" alt="Wallet">
								</span>
								<span class="xu-block__conversion-info">
									<span>Nạp vào ví 3C game</span>
									<span>Tiền sẽ được nạp vào ví</span>
								</span>
							</label>
						</li>
					</ul>
				</div>
				<div class="xu-block__amount">
					<h3 class="xu-block__amount-ttl">Chọn nhanh số tiền</h3>
					<ul class="xu-block__amount-select">
						<li class="xu-block__option">
							<select name="game" id="game" class="form-control">
								<option value="">Chọn game</option>
							</select>
						</li>
						<li class="xu-block__option">
							<select name="game" id="game" class="form-control">
								<option value="">Chọn game</option>
							</select>
						</li>
					</ul>
				</div>
				<div class="xu-block__privacy">
					Bằng việc nhấn nút "Xác nhận", bạn đồng ý rằng giao dịch này không hoàn, không hủy và tuân thủ với <a href="https://3cgame.vn/policy" target="_blank">Điều khoản sử dụng</a> và <a href="https://3cgame.vn/privacy" target="_blank">Chính sách bảo mật</a> của 3CGAME.
				</div>
				<button class="c-btn__02 xu-block__btn open-popup" type="submit">XÁC NHẬN</button>
			</div>
		</div>
	</section>
</main>